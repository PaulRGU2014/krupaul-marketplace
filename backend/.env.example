# Database
DATABASE_URL=postgresql://user:password@db:5432/marketplace

# Security
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS
# Add every frontend origin that should be allowed to reach this backend.
# To let another computer on your network connect, add its address here.
# Example: ALLOWED_ORIGINS=["http://localhost:3000","http://192.168.1.50:3000"]
ALLOWED_ORIGINS=["http://localhost:3000"]
